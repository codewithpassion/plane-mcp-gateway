# Clerk OAuth Configuration
# Get these values from your Clerk Dashboard: https://dashboard.clerk.com

# Clerk OAuth Application Client ID
CLERK_CLIENT_ID=your_clerk_client_id

# Clerk OAuth Application Client Secret
CLERK_CLIENT_SECRET=your_clerk_client_secret

# Clerk Secret Key (starts with sk_test_ or sk_live_) 
# Found in: Clerk Dashboard -> API Keys
CLERK_SECRET_KEY=sk_test_...

# Clerk Frontend API URL
# Format: https://your-subdomain.clerk.accounts.dev (for development)
# Or: https://clerk.your-domain.com (for production with custom domain)
CLERK_FRONTEND_API=https://your-subdomain.clerk.accounts.dev

# Cookie Encryption Key (generate with: openssl rand -hex 32)
# Used for HMAC signing of cookies
COOKIE_ENCRYPTION_KEY=<generate-with-openssl-rand-hex-32>

# Plane API Configuration
# Get an API key from your Plane workspace: Settings -> API Tokens
# PLANE_API_KEY=<your-plane-api-key>

# Plane workspace slug (e.g. the part after https://app.plane.so/<slug>/)
# PLANE_WORKSPACE_SLUG=<your-workspace-slug>

# Plane API base URL (https://api.plane.so for cloud; your self-hosted URL otherwise)
# PLANE_BASE_URL=https://api.plane.so

# Optional internal base URL preferred for server-to-server calls
# PLANE_INTERNAL_BASE_URL=
